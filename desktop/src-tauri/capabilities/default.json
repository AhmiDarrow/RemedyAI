{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions plus shell and updater",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-open",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "allow-open-data-folder",
    "allow-restart-server",
    "allow-app-update",
    "allow-read-dropped-files"
  ]
}
