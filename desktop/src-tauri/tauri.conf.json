{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Remedy Desktop",
  "version": "0.9.0",
  "identifier": "com.remedy.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Remedy Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Remedy Desktop"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../bin/remedy-desktop"
    ],
    "resources": {
      "../bin/remedy-desktop.exe": "remedy-desktop.exe"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
